{
  "expo": {
    "name": "Whoreagon Trail",
    "slug": "whoreagon-trail",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a0a00"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a0a00"
      },
      "package": "com.whoreagontrail.app",
      "versionCode": 1,
      "permissions": []
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#1a0a00",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200
        }
      ],
      "react-native-purchases"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "whoreagontrail",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
