{
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2020",
    "lib": ["ES2020"],
    "jsx": "react-native",
    "allowJs": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": true,
    "incremental": true
  },
  "exclude": [
    "node_modules",
    "Assets",
    "backend"
  ]
}
