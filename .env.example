# Anthropic API — required for all narrative generation
# Get your key at https://console.anthropic.com
EXPO_PUBLIC_ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# RevenueCat — required for IAP
# Android: Settings > API Keys > Public SDK Key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=your-revenuecat-android-key-here

# Build environment (set automatically by EAS, do not commit real values)
# EXPO_PUBLIC_APP_ENV=development | staging | production
